// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String
  email            String             @unique
  worker           Worker?
  passwordHash     String
  createdAt        DateTime           @default(now())
  sessions         Session[]
  claimedProviders ClaimedProvider[]

  memberships      ProviderUserRole[]
}

model Worker {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])

  bio             String?
  qualifications  String?
  languages       Language[]
  availability    WorkerAvailability[]
  specialisations Specialisation[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providers WorkerProvider[]
}

model Language {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model WorkerAvailability {
  id             String   @id @default(uuid())
  workerId       String
  worker         Worker   @relation(fields: [workerId], references: [id])
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
}

model Specialisation {
  id             String   @id @default(uuid())
  name           String
  workers        Worker[]
}

model ClaimedProvider {
  id           String    @id @default(cuid())
  slug         String    @unique
  outletKey    String?   @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  website      String?
  description  String?
  openingHours String?
  suburb       String?
  state        String?
  postcode     String?
  categories   String[]
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Provider {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  description   String?

  website       String?
  email         String?
  phone         String?

  abn           String?
  businessType  String?  // e.g. "Company", "Sole trader", "Partnership"

  ndisRegistered Boolean @default(false)
  ndisNumber     String?

  rating         Float?   // average rating 0–5
  reviewCount    Int      @default(0)

  serviceAreas   String[] @default([]) // geographic areas provider designates they serve, e.g. "Melbourne Metro", "Western Sydney"
  specialisations String[] @default([]) // e.g. "Autism", "Complex Behaviour", "Mental Health"

  services      Service[]
  locations     ServiceLocation[]
  businessHours BusinessHour[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workers WorkerProvider[]
  userRoles ProviderUserRole[]
}

model ProviderUserRole {
  id          String   @id @default(uuid())
  userId      String
  providerId  String
  role        ProviderRole
  assignedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId]) // ensures a user has only one role per provider
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    Provider @relation(fields: [providerId], references: [id])
  providerId  String
}

model ServiceLocation {
  id         String   @id @default(uuid())
  address    String
  city       String?
  state      String?
  postcode   String?
  country    String?

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model BusinessHour {
  id         String   @id @default(uuid())
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String
}

model WorkerProvider {
  id         String   @id @default(uuid())
  workerId   String
  providerId String

  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  startDate  DateTime?
  endDate    DateTime?

  @@unique([workerId, providerId])
}

// todo: remove because we're using JWT
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProviderRole {
  ADMIN
  MANAGER
  STAFF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}